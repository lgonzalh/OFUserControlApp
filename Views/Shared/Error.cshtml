@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center">
            <div class="text-danger mb-4">
                <i class="fas fa-exclamation-triangle fa-4x"></i>
            </div>
            <h1 class="h2 fw-bold text-danger mb-3">¡Ups! Algo salió mal</h1>
            <p class="text-muted fs-5 mb-4">
                Se ha producido un error inesperado. Nuestro equipo ha sido notificado y está trabajando para resolverlo.
            </p>
            <div class="d-grid gap-2 d-md-block">
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">
                    <i class="fas fa-home me-2"></i>
                    Volver al Inicio
                </a>
                <button type="button" class="btn btn-outline-secondary btn-lg" onclick="history.back()">
                    <i class="fas fa-arrow-left me-2"></i>
                    Página Anterior
                </button>
            </div>
        </div>
    </div>
</div>